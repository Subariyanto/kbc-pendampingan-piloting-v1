# Environment variables - jangan commit file ini
# Copy .env.example -> .env.local lalu isi sesuai kebutuhan

# === Mode lokal (default) ===
# Kosongkan kedua var Supabase di bawah, aplikasi otomatis pakai localStorage + akun demo

# === Mode Supabase ===
# Isi 2 var ini untuk mengaktifkan mode produksi
# VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Base path untuk GitHub Pages (tambahkan saat build production)
# VITE_BASE=/kbc-pendampingan-piloting/
